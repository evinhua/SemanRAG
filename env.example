# ── LLM ────────────────────────────────────────────────────────────────
LLM_MODEL=gemini-2.0-flash
LLM_BINDING=google-genai
LLM_API_KEY=
LLM_API_BASE=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ── Embedding ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_BINDING=google-genai
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=64

# ── Knowledge-graph storage ───────────────────────────────────────────
KG_STORAGE=networkx
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Vector storage ────────────────────────────────────────────────────
VECTOR_STORAGE=nano-vectordb
MILVUS_URI=http://localhost:19530
QDRANT_URL=http://localhost:6333

# ── Document / chunk storage ─────────────────────────────────────────
DOC_STORAGE=json
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=semanrag

# ── Redis (cache / queue) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost:5432/semanrag

# ── API server ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8020
API_WORKERS=4
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Safety / PII ─────────────────────────────────────────────────────
SAFETY_ENABLED=false
SAFETY_ENTITIES=PERSON,EMAIL_ADDRESS,PHONE_NUMBER

# ── Observability ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Working directory ─────────────────────────────────────────────────
WORKING_DIR=./data
LOG_LEVEL=INFO
